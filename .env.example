# Application
APP_ENV=development
APP_DEBUG=true
COMPOSE_PROJECT_NAME=php-core-server

# Postgres container
POSTGRES_DB=php-core-server_db
POSTGRES_USER=php-core-server_user
POSTGRES_PASSWORD=php-core-server_password

# PgBouncer container
PGBOUNCER_DB=php-core-server_db
PGBOUNCER_USER=php-core-server_user
PGBOUNCER_PASSWORD=php-core-server_password
PGBOUNCER_POOL_MODE=session
PGBOUNCER_MAX_CLIENT_CONN=100
PGBOUNCER_DEFAULT_POOL_SIZE=20

# Application connection (via PgBouncer)
DB_HOST=localhost
DB_PORT=6432
DB_NAME=php-core-server_db
DB_USER=php-core-server_user
DB_PASS=php-core-server_password
DB_DSN=pgsql:host=${DB_HOST};port=${DB_PORT};dbname=${DB_NAME}