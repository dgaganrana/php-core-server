{
    "name": "gagan/php-core-server",
    "description": "A minimalist PHP router and response layer for building web and API servers.",
    "type": "project",
    "require": {
        "php": "^8.0",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.0",
        "php-di/php-di": "^7.1",
        "psr/http-message": "^2.0",
        "guzzlehttp/psr7": "^2.9",
        "doctrine/dbal": "^4.4",
        "doctrine/migrations": "^3.9"
    },
    "autoload": {
        "files": [
            "config/constants.php"
        ],
        "psr-4": {
            "App\\": "src/",
            "Tests\\": "tests/",
            "App\\Config\\": "config/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "stop": "pkill -f 'php -S localhost:8000'",
        "restart": [
            "composer stop",
            "composer start"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    }
}
