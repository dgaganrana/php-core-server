{
    "name": "gagan/php8-learn",
    "description": "This is a learning project",
    "type": "project",
    "require": {
        "php": "^8.0",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.0"
    },
    "autoload": {
        "files": [
            "config/constants.php"
        ],
        "psr-4": {
            "App\\": "src/",
            "App\\Routing\\": "src/Routing/",
            "App\\Services\\": "src/Services",
            "App\\Http\\": "src/Http",
            "Tests\\": "tests/",
            "App\\Config\\": "config/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "stop": "pkill -f 'php -S localhost:8000'",
        "restart": [
            "composer stop",
            "composer start"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    }
}
